{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/CLYEH/graphRAG/blob/main/contracts/mcp_response.schema.json",
  "title": "graphRAG MCP retrieval response",
  "description": "Frozen contract (Track 0 P1, DESIGN §16/§27.2, DR-002) shared by every MCP retrieval tool. Rules: results are ordered score desc with ties broken by id asc; source_refs is mandatory and non-empty on every result (require_sources), with per-result_type minimums (§27.2) encoded below; debug is emitted only when query_policy.expose_debug and the caller's role allow it (null otherwise); queries are bound to the single active build (DR-001). Evolution is additive-only; a breaking change bumps schema_version and adds a DESIGN §26 entry.",
  "type": "object",
  "required": [
    "schema_version",
    "query",
    "tool",
    "project",
    "build_id",
    "results",
    "warnings"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0",
      "description": "Bumped only on breaking changes (DR-002)."
    },
    "query": {
      "type": "string"
    },
    "tool": {
      "description": "Retrieval tool that produced this response (DESIGN §9).",
      "enum": [
        "semantic_search",
        "graph_query",
        "global_summary",
        "sql_query",
        "hybrid_query"
      ]
    },
    "project": {
      "type": "string",
      "minLength": 1
    },
    "build_id": {
      "type": "string",
      "format": "uuid",
      "description": "Active build the query ran against (DR-001) — every answer names the version it read."
    },
    "results": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/RetrievalResult"
      }
    },
    "graph_context": {
      "description": "Nodes/edges/paths backing graph-flavored results; null when not applicable.",
      "anyOf": [
        {
          "$ref": "#/$defs/GraphContext"
        },
        {
          "type": "null"
        }
      ]
    },
    "warnings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Warning"
      },
      "description": "Typed warnings — degradation (store outage, guardrail block, truncation) is reported here instead of failing the whole query (DESIGN §22)."
    },
    "debug": {
      "description": "Emitted only when query_policy.expose_debug and the caller's role allow it (§16/§21); null otherwise.",
      "anyOf": [
        {
          "$ref": "#/$defs/Debug"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "$defs": {
    "SourceRefType": {
      "enum": [
        "document",
        "chunk",
        "entity",
        "relation",
        "row"
      ]
    },
    "SourceRef": {
      "type": "object",
      "required": [
        "source_type",
        "id"
      ],
      "properties": {
        "source_type": {
          "$ref": "#/$defs/SourceRefType"
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "source_uri": {
          "type": [
            "string",
            "null"
          ]
        },
        "metadata": {
          "type": "object"
        }
      }
    },
    "RetrievalResult": {
      "type": "object",
      "description": "One retrieval hit. source_refs is mandatory and non-empty (require_sources, §16/§27.2) — every answer must be traceable to sources. The allOf blocks encode the frozen §27.2 per-result_type minimums; the path rule (every edge of the returned path has a ref) is only partially machine-checkable here — full enforcement is the runtime validator's and the path_validity eval metric's job (§27.5).",
      "required": [
        "result_type",
        "id",
        "score",
        "source_refs"
      ],
      "properties": {
        "result_type": {
          "enum": [
            "chunk",
            "entity",
            "relation",
            "path",
            "row",
            "community_report"
          ]
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": [
            "string",
            "null"
          ]
        },
        "text": {
          "type": [
            "string",
            "null"
          ]
        },
        "score": {
          "type": "number"
        },
        "confidence": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/SourceRef"
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "result_type": {
                "const": "chunk"
              }
            },
            "required": [
              "result_type"
            ]
          },
          "then": {
            "properties": {
              "source_refs": {
                "contains": {
                  "description": "§27.2: chunk → ≥1 chunk ref with source_uri + offsets.",
                  "properties": {
                    "source_type": {
                      "const": "chunk"
                    },
                    "source_uri": {
                      "type": "string",
                      "minLength": 1
                    },
                    "metadata": {
                      "type": "object",
                      "required": [
                        "start_offset",
                        "end_offset"
                      ],
                      "properties": {
                        "start_offset": {
                          "type": "integer",
                          "minimum": 0
                        },
                        "end_offset": {
                          "type": "integer",
                          "minimum": 0
                        }
                      }
                    }
                  },
                  "required": [
                    "source_type",
                    "source_uri",
                    "metadata"
                  ]
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "result_type": {
                "const": "entity"
              }
            },
            "required": [
              "result_type"
            ]
          },
          "then": {
            "properties": {
              "source_refs": {
                "contains": {
                  "description": "§27.2: entity → ≥1 mention (chunk or row).",
                  "properties": {
                    "source_type": {
                      "enum": [
                        "chunk",
                        "row"
                      ]
                    }
                  },
                  "required": [
                    "source_type"
                  ]
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "result_type": {
                "const": "relation"
              }
            },
            "required": [
              "result_type"
            ]
          },
          "then": {
            "properties": {
              "source_refs": {
                "contains": {
                  "description": "§27.2/§27.4: relation → ≥1 relation_evidence-backed ref that stays auditable after prune. Chunk evidence carries quote + source_uri + offsets (the extraction span is always known); document evidence carries quote + source_uri only (it backs manual/document-level citations — §4 evidence_type includes `manual`, which has no span); row evidence carries table + pk.",
                  "anyOf": [
                    {
                      "properties": {
                        "source_type": {
                          "const": "chunk"
                        },
                        "source_uri": {
                          "type": "string",
                          "minLength": 1
                        },
                        "metadata": {
                          "type": "object",
                          "required": [
                            "quote",
                            "start_offset",
                            "end_offset"
                          ],
                          "properties": {
                            "quote": {
                              "type": "string",
                              "minLength": 1,
                              "maxLength": 512
                            },
                            "start_offset": {
                              "type": "integer",
                              "minimum": 0
                            },
                            "end_offset": {
                              "type": "integer",
                              "minimum": 0
                            }
                          }
                        }
                      },
                      "required": [
                        "source_type",
                        "source_uri",
                        "metadata"
                      ]
                    },
                    {
                      "properties": {
                        "source_type": {
                          "const": "document"
                        },
                        "source_uri": {
                          "type": "string",
                          "minLength": 1
                        },
                        "metadata": {
                          "type": "object",
                          "required": [
                            "quote"
                          ],
                          "properties": {
                            "quote": {
                              "type": "string",
                              "minLength": 1,
                              "maxLength": 512
                            }
                          }
                        }
                      },
                      "required": [
                        "source_type",
                        "source_uri",
                        "metadata"
                      ]
                    },
                    {
                      "properties": {
                        "source_type": {
                          "const": "row"
                        },
                        "metadata": {
                          "type": "object",
                          "required": [
                            "table",
                            "pk"
                          ],
                          "properties": {
                            "table": {
                              "type": "string",
                              "minLength": 1
                            },
                            "pk": {
                              "oneOf": [
                                {
                                  "type": "string",
                                  "minLength": 1
                                },
                                {
                                  "type": "integer"
                                },
                                {
                                  "type": "object",
                                  "minProperties": 1
                                }
                              ]
                            }
                          }
                        }
                      },
                      "required": [
                        "source_type",
                        "metadata"
                      ]
                    }
                  ]
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "result_type": {
                "const": "path"
              }
            },
            "required": [
              "result_type"
            ]
          },
          "then": {
            "properties": {
              "source_refs": {
                "contains": {
                  "description": "§27.2: path → every edge has a ref; the schema can only require ≥1 relation ref, the runtime validator checks per-edge completeness.",
                  "properties": {
                    "source_type": {
                      "const": "relation"
                    }
                  },
                  "required": [
                    "source_type"
                  ]
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "result_type": {
                "const": "row"
              }
            },
            "required": [
              "result_type"
            ]
          },
          "then": {
            "properties": {
              "source_refs": {
                "contains": {
                  "description": "§27.2: row → table + pk.",
                  "properties": {
                    "source_type": {
                      "const": "row"
                    },
                    "metadata": {
                      "type": "object",
                      "required": [
                        "table",
                        "pk"
                      ],
                      "properties": {
                        "table": {
                          "type": "string",
                          "minLength": 1
                        },
                        "pk": {
                          "oneOf": [
                            {
                              "type": "string",
                              "minLength": 1
                            },
                            {
                              "type": "integer"
                            },
                            {
                              "type": "object",
                              "minProperties": 1
                            }
                          ]
                        }
                      }
                    }
                  },
                  "required": [
                    "source_type",
                    "metadata"
                  ]
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "result_type": {
                "const": "community_report"
              }
            },
            "required": [
              "result_type"
            ]
          },
          "then": {
            "properties": {
              "source_refs": {
                "contains": {
                  "description": "§27.2: community_report → member entity refs.",
                  "properties": {
                    "source_type": {
                      "const": "entity"
                    }
                  },
                  "required": [
                    "source_type"
                  ]
                }
              }
            }
          }
        }
      ]
    },
    "GraphNode": {
      "type": "object",
      "required": [
        "id"
      ],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "type": {
          "type": [
            "string",
            "null"
          ]
        },
        "label": {
          "type": [
            "string",
            "null"
          ]
        },
        "properties": {
          "type": "object"
        }
      }
    },
    "GraphEdge": {
      "type": "object",
      "required": [
        "id",
        "src",
        "dst",
        "type"
      ],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "src": {
          "type": "string",
          "format": "uuid"
        },
        "dst": {
          "type": "string",
          "format": "uuid"
        },
        "type": {
          "type": "string"
        },
        "confidence": {
          "type": [
            "number",
            "null"
          ]
        },
        "properties": {
          "type": "object"
        }
      }
    },
    "GraphPath": {
      "type": "object",
      "required": [
        "nodes",
        "edges"
      ],
      "properties": {
        "nodes": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uuid"
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uuid"
          }
        }
      }
    },
    "GraphContext": {
      "type": "object",
      "required": [
        "nodes",
        "edges"
      ],
      "properties": {
        "nodes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/GraphNode"
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/GraphEdge"
          }
        },
        "paths": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/GraphPath"
          }
        }
      }
    },
    "WarningCode": {
      "description": "Frozen warning-code enum (DESIGN §27.2; additive-only, kept identical to contracts/openapi.yaml).",
      "enum": [
        "STORE_UNAVAILABLE",
        "MODE_SKIPPED",
        "PARTIAL_RESULTS",
        "LOW_CONFIDENCE",
        "GUARDRAIL_BLOCKED",
        "TRUNCATED"
      ]
    },
    "Warning": {
      "type": "object",
      "required": [
        "code",
        "message"
      ],
      "properties": {
        "code": {
          "$ref": "#/$defs/WarningCode"
        },
        "message": {
          "type": "string"
        }
      }
    },
    "QueryMode": {
      "enum": [
        "semantic",
        "graph",
        "sql",
        "global",
        "hybrid"
      ]
    },
    "RoutingDecision": {
      "type": "object",
      "description": "Router trace (§16) — which modes ran and why.",
      "required": [
        "selected",
        "skipped"
      ],
      "properties": {
        "selected": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/QueryMode"
          }
        },
        "skipped": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/QueryMode"
          }
        },
        "reason": {
          "type": [
            "string",
            "null"
          ]
        },
        "confidence": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "Debug": {
      "type": "object",
      "description": "Typed debug block (§16); evolution is additive. Kept shape-identical to QueryDebug in contracts/openapi.yaml.",
      "required": [
        "stores_used",
        "retrieval_plan",
        "routing_decision",
        "latency_ms"
      ],
      "properties": {
        "stores_used": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "retrieval_plan": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "routing_decision": {
          "description": "Null for single-mode tools that bypass the router.",
          "anyOf": [
            {
              "$ref": "#/$defs/RoutingDecision"
            },
            {
              "type": "null"
            }
          ]
        },
        "latency_ms": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
