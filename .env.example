# Copy to .env and fill in. Loaded by core.config.Settings (prefix GRAPHRAG_).
GRAPHRAG_POSTGRES_DSN=postgresql://graphrag:graphrag@localhost:5432/graphrag
GRAPHRAG_NEO4J_URI=bolt://localhost:7687
GRAPHRAG_NEO4J_USER=neo4j
GRAPHRAG_NEO4J_PASSWORD=graphrag-dev
GRAPHRAG_QDRANT_URL=http://localhost:6333
GRAPHRAG_REDIS_URL=redis://localhost:6379/0

# LLM (default provider: OpenAI — see DESIGN.md §3)
GRAPHRAG_LLM_PROVIDER=openai
GRAPHRAG_LLM_MODEL=gpt-4o
GRAPHRAG_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_API_KEY=
